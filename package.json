{
  "name": "tree-sitter-arche",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Arche language",
  "main": "bindings/node",
  "keywords": ["parser", "tree-sitter", "arche", "syntax-highlighting"],
  "author": "Curt Reyes",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "build": "tree-sitter generate && node-gyp build",
    "postinstall": "npm run build",
    "test": "tree-sitter test"
  },
  "dependencies": {
    "nan": "^2.19.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0",
    "node-gyp": "^10.0.0"
  },
  "tree-sitter": [
    {
      "scope": "source.arche",
      "file-types": ["arche"],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "indents": "queries/indents.scm"
    }
  ]
}
